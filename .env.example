BACKEND_PORT=8010
FRONTEND_PORT=3010
DATABASE_FILE=scoutrr.db
SCOUTRR_LOG_FILE=scoutrr.log
EBAY_APP_ID=
# Get these from the eBay Developer Program app keys page: https://developer.ebay.com/my/keys
EBAY_CLIENT_ID=your-ebay-client-id
EBAY_CLIENT_SECRET=your-ebay-client-secret
# Global default marketplace for new watches. Per-watch region can override this in the app.
EBAY_MARKETPLACE_ID=EBAY_US
EBAY_DELETION_TOKEN=replace-with-a-random-32-to-80-character-token
EBAY_DELETION_ENDPOINT_URL=https://scoutrr.karphost.org/ebay/deletion-notification
DISCORD_WEBHOOK_URL=
BUDGET_WARNING_THRESHOLD=0.9
